{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PROJECT_DIR}\"/.claude/hooks/check-elixir-host.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(.agents/agents/scripts/code-quality-check.sh *)",
      "Bash(.agents/agents/scripts/dialyzer-check.sh *)",
      "Bash(.agents/agents/scripts/run-tests.sh *)",
      "Bash(.claude/agents/scripts/code-quality-check.sh *)",
      "Bash(.claude/agents/scripts/dialyzer-check.sh *)",
      "Bash(.claude/agents/scripts/run-tests.sh *)"
    ]
  }
}